# Zapier Webhook URL for GHL Integration
# Get this from your Zapier webhook trigger (Webhooks by Zapier -> Catch Hook)
# Format: https://hooks.zapier.com/hooks/catch/YOUR_ID/YOUR_CODE/
VITE_ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/YOUR_ID/YOUR_CODE/

# Calendly URL (optional - already set in code)
VITE_CALENDLY_URL=https://calendly.com/gufy/strategy-call
